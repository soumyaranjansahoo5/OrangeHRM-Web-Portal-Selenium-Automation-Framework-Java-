<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  OrangeHRM Web Portal – Selenium Automation Framework
  TestNG Master Suite
  Author : Soumyaranjan Sahoo
  Modules : Login | Dashboard | PIM/Employee | Admin | Leave |
            Recruitment | My Info | Time | Directory | Performance
-->
<suite name="OrangeHRM Automation Suite"
       verbose="1"
       parallel="none"
       thread-count="1">

    <description>OrangeHRM Web Portal Selenium Java Automation Test Suite</description>

    <!-- ═══════════════ Global Listeners ════════════════════════════════════ -->
    <listeners>
        <listener class-name="com.orangehrm.listeners.TestListener"/>
    </listeners>

    <!-- ═══════════════ 1. Login Module ════════════════════════════════════ -->
    <test name="Login Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.LoginTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 2. Dashboard Module ════════════════════════════════ -->
    <test name="Dashboard Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.DashboardTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 3. PIM / Employee Module ════════════════════════════ -->
    <test name="PIM Employee Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.EmployeeTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 4. Admin / User Management Module ══════════════════ -->
    <test name="Admin Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.AdminTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 5. Leave Module ════════════════════════════════════ -->
    <test name="Leave Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.LeaveTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 6. Recruitment Module ══════════════════════════════ -->
    <test name="Recruitment Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.RecruitmentTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 7. My Info Module ══════════════════════════════════ -->
    <test name="My Info Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.MyInfoTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 8. Time Module ═════════════════════════════════════ -->
    <test name="Time Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.TimeTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 9. Directory Module ════════════════════════════════ -->
    <test name="Directory Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.DirectoryTests"/>
        </classes>
    </test>

    <!-- ═══════════════ 10. Performance Module ══════════════════════════════ -->
    <test name="Performance Module Tests" preserve-order="true">
        <classes>
            <class name="com.orangehrm.tests.PerformanceTests"/>
        </classes>
    </test>

</suite>
